<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="SchedulerApp.Views.EventBlockView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border
        BackgroundColor="{Binding BackgroundColor}"
        Stroke="Transparent"
        StrokeShape="RoundRectangle 4"
        Padding="0">
        <Grid ColumnDefinitions="4,*">
            <!-- Left accent strip: orange for AI-scheduled, blue for manual -->
            <BoxView
                Grid.Column="0"
                BackgroundColor="{Binding AccentStripColor}" />

            <!-- Content -->
            <VerticalStackLayout Grid.Column="1" Padding="6,4" Spacing="1">
                <Label
                    Text="{Binding Title}"
                    FontSize="12"
                    FontAttributes="Bold"
                    TextColor="White"
                    LineBreakMode="TailTruncation"
                    MaxLines="1" />
                <Label
                    Text="{Binding TimeLabel}"
                    FontSize="10"
                    TextColor="#D0E8FF"
                    LineBreakMode="TailTruncation"
                    MaxLines="1" />
            </VerticalStackLayout>
        </Grid>
    </Border>

</ContentView>
