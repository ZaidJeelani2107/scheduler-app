<?xml version="1.0" encoding="utf-8"?>
<!--
    Allows cleartext HTTP to the Android emulator host alias (10.0.2.2)
    so the app can reach the local ASP.NET Core API during development.
    Production builds should never use cleartext traffic.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
